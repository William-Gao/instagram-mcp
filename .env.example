# Required: long-lived access token obtained from Instagram Login API
# Token starts with "IGAA..." (NOT "EAA..." - that's a Facebook Graph API token)
# See: https://developers.facebook.com/docs/instagram-platform/instagram-api-with-instagram-login/
INSTAGRAM_ACCESS_TOKEN=

# Optional: needed only if you want this server to refresh tokens automatically
# Get these from your Meta app dashboard (Instagram Platform > API Setup)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# Optional: pin a Graph API version (defaults to v23.0)
# INSTAGRAM_API_VERSION=v23.0

# Optional: enable Facebook Graph API extras (business_discovery, hashtag search,
# find_outlier_posts, analyze_competitor). Requires linking your IG to a Facebook
# Page and generating a long-lived Page access token (EAA...) via the Meta dev
# console. After setting the token, call discover_fb_setup once to find your IG
# Business Account ID and paste it below.
# INSTAGRAM_FB_ACCESS_TOKEN=EAA...
# INSTAGRAM_FB_IG_USER_ID=

# Optional: local persistence path (default ~/.instagram-mcp/)
# INSTAGRAM_DATA_DIR=
